JENKINS_HOME_PATH=./jenkins_home
# Opción A: coloca aquí la clave pública (una línea), si prefieres no montar el archivo authorized_keys.
JENKINS_AGENT_SSH_PUBLIC_KEY=

# Nota: la red `red-integracion` debe existir para conectar Jenkins y los contenedores.
# Puedes crearla con:
#   docker network create red-integracion
